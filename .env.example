# Application
NEXT_PUBLIC_APP_NAME=Queue
# Public URL (Vercel fills this automatically on deploy)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database (MongoDB Atlas - free tier)
# Get yours at https://www.mongodb.com/atlas
# Format: mongodb+srv://<user>:<password>@<cluster>.xxxxx.mongodb.net/queue
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/queue

# WhatsApp Integration
WHATSAPP_API_KEY=
WHATSAPP_PHONE_NUMBER=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# Email Service (Optional)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=

# Payment Gateway (Optional - Future)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Analytics (Optional)
GOOGLE_ANALYTICS_ID=

# API Rate Limiting
API_RATE_LIMIT=100

# Session
NEXT_PUBLIC_SESSION_TIMEOUT=3600000
